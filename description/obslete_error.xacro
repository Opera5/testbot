<?xml version="1.0"?>


<robot xmlns:xacro="http://www.ros.org/wiki/xacro" >


<material name="green">
    <color rgba="0.0 0.7 0.0 1.0"/>
</material>

<material name="blue">
<color rgba="0.0 0.0 1.0 1.0"/>
</material>

<material name="red">
    <color rgba="1.0 0.0 0.0 1.0"/>
</material>

<material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
</material>

<material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
</material>

<!--- All Robots links-->

<!--Base_link properties-->
<link name="base_footprint"/>

<link name="base_link">
    <visual>
        <geometry>
            <box size="0.6 0.4 0.2"/>
        </geometry>
        <origin xyz="0.0 0.0 0.1" rpy="0.0 0.0 0.0"/>
        <material name="green"/>
    </visual>

    <collision>
        <geometry>
            <box size="0.6 0.4 0.2"/>
        </geometry>
        <origin xyz="0.0 0.0 0.1" rpy="0.0 0.0 0.0"/>
    </collision> 
    <inertial>
        <mass value="1.0"/>
        <origin xyz="0 0 0.1"/> <!-- Assuming the center of mass is at the origin -->
        <inertia ixx="0.0167" ixy="0.0" ixz="0.0" iyy="0.0333" iyz="0.0" izz="0.0433"/>
    </inertial>

</link>

<!--Lidar properties-->
<link name = "lidar">


<robot xmlns:xacro="http://www.ros.org/wiki/xacro"  name="roboct">


<material name="green">
    <color rgba="0.0 0.7 0.0 1.0"/>
</material>

<material name="blue">
<color rgba="0.0 0.0 1.0 1.0"/>
</material>

<material name="red">
    <color rgba="1.0 0.0 0.0 1.0"/>
</material>

<material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
</material>

<material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
</material>

<!--- All Robots links-->

<!--Base_link properties-->
<link name="base_footprint"/>

<link name="base_link">
    <visual>
        <geometry>
            <box size="0.6 0.4 0.2"/>
        </geometry>
        <origin xyz="0.0 0.0 0.1" rpy="0.0 0.0 0.0"/>
        <material name="green"/>
    </visual>

    <collision>
        <geometry>
            <box size="0.6 0.4 0.2"/>
        </geometry>
        <origin xyz="0.0 0.0 0.1" rpy="0.0 0.0 0.0"/>
    </collision> 
    <inertial>
        <mass value="1.0"/>
        <origin xyz="0 0 0.1"/> <!-- Assuming the center of mass is at the origin -->
        <inertia ixx="0.0167" ixy="0.0" ixz="0.0" iyy="0.0333" iyz="0.0" izz="0.0433"/>
    </inertial>

</link>

<!--Lidar properties-->
<link name = "lidar">
    <visual>
            <geometry>
                <cylinder radius="0.1" length="0.05"/>
            </geometry>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <material name="black"/>
    </visual>   
    <collision>
        <geometry>
            <cylinder radius="0.1" length="0.05"/>
        </geometry>
    </collision> 
    <inertial>
            <mass value="1.0"/>
            <origin xyz="0 0 0"/>
            <inertia ixx="0.001458" iyy="0.001458" izz="0.00125" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
</link>   

<!--Left Wheel properties-->
<link name = "left_wheel">
    <visual>
            <geometry>
                <cylinder radius="0.1" length="0.05"/>
            </geometry>
            <origin xyz="0.0 0.0 0.0" rpy="1.57 0.0 0.0"/>
            <material name="blue"/>
    </visual>  

    <collision>
        <geometry>
            <cylinder radius="0.1" length="0.05"/>
        </geometry>
        <origin xyz="0.0 0.0 0.0" rpy="1.57 0.0 0.0"/>
    </collision> 
    <inertial>
            <mass value="1.0"/>
            <origin xyz="0 0 0"/>
            <inertia ixx="0.001458" iyy="0.001458" izz="0.00125" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
</link> 

<!--Right Wheel properties-->
<link name = "right_wheel">
    <visual>
            <geometry>
                <cylinder radius="0.1" length="0.05"/>
            </geometry>
            <origin xyz="0.0 0.0 0.0" rpy="1.570 0.0 0.0"/>
            <material name="blue"/>
    </visual>  

    <collision>
        <geometry>
            <cylinder radius="0.1" length="0.05"/>
        </geometry>
        <origin xyz="0.0 0.0 0.0" rpy="1.57 0.0 0.0"/>
    </collision>
    <inertial>
        <mass value="1.0"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.001458" iyy="0.001458" izz="0.00125" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
</link> 

<!--Caster Wheel properties-->
<link name = "caster_wheel">
<visual>
        <geometry>
            <sphere radius="0.05"/>
        </geometry>
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <material name="white"/>
</visual>
<collision>
        <geometry>
            <sphere radius="0.05"/>
        </geometry>
</collision>   
<inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/> <!-- Assume the center of mass is at the origin -->
    <mass value="1.0"/>
    <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
  </inertial> 
</link> 


<!--- All joints for links-->

<joint name="base_lidar" type="fixed">
    <origin xyz="0.0 0.0 0.225" rpy="0.0 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="lidar"/>
    <axis xyz="0.0 0.0 0.0"/>
    <limit lower="0.0" upper="0.0" effort="0.0" velocity="0.0"/>
</joint>

<joint name="base_left_wheel" type="continuous">
    <origin xyz="-0.15 0.225 0.0" rpy="0.0 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <axis xyz="0.0 1.0 0.0"/>
    <limit lower="0.0" upper="0.0" effort="0.0" velocity="1000.0"/>
    <dynamics damping="1.0" friction="1.0"/>
</joint>

<joint name="base_right_wheel" type="continuous">
    <origin xyz="-0.15 -0.225 0.0" rpy="0.0 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <axis xyz="0.0 1.0 0.0"/>
    <limit lower="0.0" upper="0.0" effort="0.0" velocity="1000.0"/>
    <dynamics damping="1.0" friction="1.0"/>
</joint>

<joint name="base_caster" type="fixed">
    <origin xyz="0.2 0.0 -0.04" rpy="0.0 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <axis xyz="0.0 0.0 0.0"/>
    <limit lower="0.0" upper="0.0" effort="0.0" velocity="0.0"/>
    <dynamics damping="1.0" friction="1.0"/>
    
</joint>

<joint name="base_link_footprint_joint" type="fixed">
    <origin xyz="0.0 0.0 0.1" rpy="0.0 0.0 0.0"/>
    <parent link="base_footprint"/>
    <child link="base_link"/>
   
</joint>

</robot>

    <visual>
            <geometry>
                <cylinder radius="0.1" length="0.05"/>
            </geometry>
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
            <material name="black"/>
    </visual>   
    <collision>
        <geometry>
            <cylinder radius="0.1" length="0.05"/>
        </geometry>
    </collision> 
    <inertial>
            <mass value="1.0"/>
            <origin xyz="0 0 0"/>
            <inertia ixx="0.001458" iyy="0.001458" izz="0.00125" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
</link>   

